# Ignore raw dataset files and large binaries
raw/

# Keep sample part2 visible (do not ignore its contents)
!sample/part2/
!sample/part2/**
!sample/part2/raw/
!sample/part2/raw/**

# Project-level dataset folders
dataset/
Word_Level_Training_Set/



# Ignore specific large file types in data
*.mat
*.h5
*.hdf5
*.npz
*.npy
*.tar
*.tar.gz
*.zip
*.tgz

# Keep README and this .gitignore tracked
!README.md
!.gitignore

# OS artifacts
.DS_Store
Thumbs.db